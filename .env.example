# Spoor — copy to .env (gitignored). Never commit real values.

# --- LLM provider (orchestration) ---
# OpenRouter (OpenAI-compatible). Set ONE of the keys below.
# Preferred: a dedicated per-project key, exported in ~/Documents/secret/.env:
#   export SPOOR_OPENROUTER_API_KEY=sk-or-...
# Generic fallback (e.g. a judge cloning the repo into ./.env):
SPOOR_OPENROUTER_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# All agents (specialists AND lead) — Sonnet is the default for the whole graph.
# The lead only orchestrates (routing decisions, a few output tokens per turn);
# the deterministic completeness gate backstops it, so no premium tier is needed.
# Confirm the current id at https://openrouter.ai/models
SPOOR_MODEL=anthropic/claude-sonnet-4.6
# Lead investigator + reporter — optional override; UNSET = same model as SPOOR_MODEL.
# (Leave unset for sonnet-only. A premium lead is supported but not required.)
# SPOOR_LEAD_MODEL=
# Direct-Anthropic fallback (used only if OPENROUTER_API_KEY is unset).
ANTHROPIC_API_KEY=

# --- evidence + audit ---
EVIDENCE_ROOT=
# Writable scratch for tool artifacts (.plaso, extractions, yara rules).
# Must be DISJOINT from EVIDENCE_ROOT; enables icat/yara/plaso tools on the MCP server.
SPOOR_WORKSPACE=workspace
SPOOR_AUDIT_PATH=runs/audit.jsonl

# --- optional ---
VT_API_KEY=
